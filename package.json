{
  "name": "multi-tenant-rag",
  "version": "1.0.0",
  "description": "Multi-tenant RAG system with strict tenant isolation",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "test": "jest --forceExit",
    "db:migrate": "ts-node src/models/migrate.ts"
  },
  "dependencies": {
    "express": "^4.18.2",
    "pg": "^8.11.3",
    "openai": "^4.28.0",
    "pdf-parse": "^1.1.1",
    "multer": "^1.4.5-lts.1",
    "uuid": "^9.0.0",
    "dotenv": "^16.4.1",
    "express-rate-limit": "^7.1.5",
    "joi": "^17.12.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/pg": "^8.11.0",
    "@types/multer": "^1.4.11",
    "@types/uuid": "^9.0.7",
    "@types/pdf-parse": "^1.1.4",
    "@types/node": "^20.11.5",
    "@types/jest": "^29.5.11",
    "typescript": "^5.3.3",
    "ts-node-dev": "^2.0.0",
    "ts-node": "^10.9.2",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "supertest": "^6.3.4",
    "@types/supertest": "^6.0.2"
  }
}
